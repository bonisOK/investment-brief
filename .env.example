# Copy to .env and fill in. NEVER put real values in this file —
# it is committed to the (public) repo.
FMP_API_KEY=your-financialmodelingprep-key
GEMINI_API_KEY=your-google-ai-studio-key
APP_PASSWORD=            # optional: basic auth for the local/Railway server
SHEET_ID=your-google-sheet-id
# Apps Script web-app URL (deploy the sheet's script as a web app; its doGet
# should call updateMINTprices). Pipeline GETs it before reading the sheet.
APPS_SCRIPT_URL=
DB_PATH=data/brief.db
